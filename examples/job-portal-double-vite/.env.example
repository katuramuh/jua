# =============================================================================
# Job Portal — Double Architecture (Web + API)
# =============================================================================

# App
APP_NAME=job-portal
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
WEB_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgres://grit:grit@localhost:5432/job_portal?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-64-chars-minimum-random-string-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/auth/github/callback

# TOTP 2FA
TOTP_ISSUER=JobPortal

# File Storage (S3-compatible)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=job-portal
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@jobs.example.com

# AI (optional)
AI_GATEWAY_API_KEY=
AI_PROVIDER=claude

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# CORS
CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
